import os
import json
import time
import random
import requests
import pandas as pd
from bs4 import BeautifulSoup
from PIL import Image
from io import BytesIO

OUTPUT_DIR = "data"
MIN_SIZE = (100, 100)

CATEGORIES = {
    "glass": ["glass waste", "glass bottle trash"],
    "paper": ["paper waste", "newspaper trash"],
    "metal": ["metal can waste", "aluminum trash"]
}

HEADERS = {
    "User-Agent": "Mozilla/5.0"
}

def get_urls(query, limit=80):
    urls = []
    offset = 0

    while len(urls) < limit:
        r = requests.get(
            "https://www.bing.com/images/search",
            params={"q": query, "first": offset},
            headers=HEADERS
        )

        soup = BeautifulSoup(r.text, "html.parser")
        items = soup.find_all("a", class_="iusc")

        if not items:
            break

        for item in items:
            try:
                data = json.loads(item.get("m"))
                url = data.get("murl")
                if url and url.startswith("http"):
                    urls.append(url)
            except:
                pass

        offset += 35
        time.sleep(1)

    return urls[:limit]

def save_img(url, path):
    try:
        r = requests.get(url, timeout=5)
        img = Image.open(BytesIO(r.content))
        img.verify()

        img = Image.open(BytesIO(r.content))
        if img.size[0] < MIN_SIZE[0] or img.size[1] < MIN_SIZE[1]:
            return False

        img.convert("RGB").save(path, "JPEG")
        return True
    except:
        return False

def scrape():
    for cls, queries in CATEGORIES.items():
        folder = os.path.join(OUTPUT_DIR, cls)
        os.makedirs(folder, exist_ok=True)

        count = 0
        for q in queries:
            urls = get_urls(q)

            for url in urls:
                name = f"{count}.jpg"
                path = os.path.join(folder, name)

                if save_img(url, path):
                    count += 1

                time.sleep(random.uniform(0.2, 0.5))

def clean():
    for cls in os.listdir(OUTPUT_DIR):
        folder = os.path.join(OUTPUT_DIR, cls)

        for f in os.listdir(folder):
            path = os.path.join(folder, f)
            try:
                with Image.open(path) as img:
                    img.verify()
            except:
                os.remove(path)

def build_csv():
    data = []

    for cls in os.listdir(OUTPUT_DIR):
        folder = os.path.join(OUTPUT_DIR, cls)

        for f in os.listdir(folder):
            path = os.path.join(folder, f)
            data.append([path, cls])

    df = pd.DataFrame(data, columns=["image", "label"])
    df.to_csv("dataset.csv", index=False)

if __name__ == "__main__":
    scrape()
    clean()
    build_csv()